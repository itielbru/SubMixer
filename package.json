{
  "name": "submixer",
  "version": "1.2.0",
  "description": "SubMixer — Mux video tracks and external subtitles, with offset/speed sync.",
  "main": "./out/main/index.js",
  "author": "Itiel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/itielbru/SubMixer.git"
  },
  "homepage": "https://github.com/itielbru/SubMixer#readme",
  "bugs": {
    "url": "https://github.com/itielbru/SubMixer/issues"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "clean:release": "node scripts/clean-release.cjs",
    "build": "node scripts/clean-release.cjs && electron-vite build && electron-builder --win nsis",
    "build:newdir": "electron-vite build && electron-builder --win nsis --config.directories.output=release-new",
    "build:portable": "node scripts/clean-release.cjs && electron-vite build && electron-builder --win portable",
    "build:dir": "node scripts/clean-release.cjs && electron-vite build && electron-builder --win --dir",
    "build:mac": "node scripts/clean-release.cjs && electron-vite build && electron-builder --mac",
    "build:linux": "node scripts/clean-release.cjs && electron-vite build && electron-builder --linux",
    "release": "node scripts/clean-release.cjs && electron-vite build && electron-builder --win nsis portable --publish always",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "setup:ffmpeg": "node scripts/setup-ffmpeg.cjs",
    "setup:fonts": "node scripts/setup-fonts.cjs",
    "postinstall": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "chardet": "^2.0.0",
    "electron-log": "^5.4.4",
    "electron-updater": "^6.8.3",
    "iconv-lite": "^0.6.3"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "@vitest/coverage-v8": "^2.1.9",
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^9.1.2",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^15.15.0",
    "prettier": "^3.8.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.59.4",
    "vite": "^5.3.4",
    "vitest": "^2.1.9",
    "@playwright/test": "^1.49.0",
    "playwright": "^1.49.0"
  }
}
